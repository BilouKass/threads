# ---- HTTP server ----
PORT=3000
HOST=0.0.0.0
# Base URL of the admin API + UI (used for display/links). The OAuth redirect is
# opened by your browser, so http://localhost:3000 works locally without exposing
# anything. Image hosting uses the dedicated media server (see MEDIA_* below).
PUBLIC_BASE_URL=http://localhost:3000
LOG_LEVEL=info

# ---- Database ----
# When running via docker-compose, host is "db". Locally use "localhost".
DATABASE_URL=postgresql://threads:threads@localhost:5432/threads?schema=public

# ---- Threads / Meta app credentials ----
# Create an app at https://developers.facebook.com/ with the Threads API product.
THREADS_APP_ID=2247588359316039
THREADS_APP_SECRET=dccaa72a4576aa4dd5d40aa23a32b168
# Must match exactly one of the redirect URIs configured in the Threads app settings.
THREADS_REDIRECT_URI=http://localhost:3000/auth/threads/callback
# Scopes requested at authorization time (comma separated).
THREADS_SCOPES=threads_basic,threads_content_publish,threads_manage_replies,threads_read_replies,threads_manage_insights

# ---- Security ----
# 32-byte key (hex = 64 chars) used to encrypt access tokens at rest (AES-256-GCM).
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=552b5ebe698ee671e56bef82e9a13e7482e12c10f68722c6c7dc275481d232dd
# Master API key auto-created on first boot if no key exists (printed to logs once).
# You can also create more keys with: npm run seed:apikey -- "my n8n key"

# ---- Web UI users / sessions ----
# First-admin bootstrap: if no admin exists and ADMIN_PASSWORD is set, an admin
# user (ADMIN_USERNAME) is created on boot. You can also use: npm run seed:user.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=HelloWorld
# Session lifetime (days). Set COOKIE_SECURE=true when served over HTTPS.
SESSION_TTL_DAYS=7
COOKIE_SECURE=false

# ---- Scheduler ----
# How often (seconds) the worker polls the DB for due jobs.
SCHEDULER_POLL_SECONDS=15
# Refresh long-lived tokens when they expire within this many days.
TOKEN_REFRESH_THRESHOLD_DAYS=10

# ---- Media (images) ----
# Uploaded images are stored privately and exposed only via a signed, expiring
# /media URL, then deleted after the post is published. This TTL (minutes) bounds
# how long such a link stays valid (and how far ahead an image post can be scheduled).
MEDIA_SIGNED_URL_TTL_MINUTES=1440

# Dedicated public media server. THIS is the only port that must be reachable
# from the Internet (port-forward / firewall) so Meta can download images.
MEDIA_PORT=8080
MEDIA_HOST=0.0.0.0
# Public IP or domain that points to MEDIA_PORT. Leave empty or "auto" to
# auto-detect your public IP at boot. Set it explicitly for a stable value, e.g.:
#   MEDIA_PUBLIC_HOST=203.0.113.42
#   MEDIA_PUBLIC_HOST=media.mondomaine.com
MEDIA_PUBLIC_HOST=auto
# Optional full override (e.g. behind HTTPS / reverse proxy). Takes precedence.
#   MEDIA_PUBLIC_BASE_URL=https://media.mondomaine.com
MEDIA_PUBLIC_BASE_URL=http://88.167.100.149/
