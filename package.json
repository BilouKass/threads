{
  "name": "threads-manager",
  "version": "0.1.0",
  "description": "Multi-account Threads (Meta) manager: OAuth + token storage/refresh, scheduled posts, replies, controllable via web UI or programmatic API (n8n-friendly).",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -k -n api,worker -c blue,green \"npm:dev:api\" \"npm:dev:worker\"",
    "start": "concurrently -k -n api,worker -c blue,green \"npm:start:api\" \"npm:start:worker\"",
    "dev:api": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "build": "tsc -p tsconfig.json",
    "start:api": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:dev": "prisma migrate dev",
    "db:push": "prisma db push",
    "seed:apikey": "tsx src/scripts/createApiKey.ts",
    "seed:user": "tsx src/scripts/createUser.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/static": "^7.0.4",
    "@prisma/client": "^5.18.0",
    "fastify": "^4.28.1",
    "pino": "^9.3.2",
    "undici": "^6.19.8",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.15",
    "concurrently": "^9.2.1",
    "pino-pretty": "^11.2.2",
    "prisma": "^5.18.0",
    "tsx": "^4.17.0",
    "typescript": "^5.5.4"
  }
}
